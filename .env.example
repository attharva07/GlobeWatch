APP_NAME=GlobeWatch API
APP_VERSION=0.2.0
ENVIRONMENT=local
DEBUG=false
API_PREFIX=/api/v1
DATABASE_URL=sqlite:///./globewatch.db
SECRET_KEY=local-dev-change-me
ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

API_KEY_ENABLED=false
API_KEY_HEADER_NAME=X-API-Key
API_KEYS=[]

RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
LOG_LEVEL=INFO

ENABLE_MOCK_SEED=true
INGESTION_PROVIDER=gdelt
INGESTION_ENABLED=true
INGESTION_INTERVAL_SECONDS=900
INGESTION_STARTUP_RUN=true
GDELT_BASE_URL=https://api.gdeltproject.org/api/v2/doc/doc
GDELT_QUERY=(flood OR wildfire OR earthquake OR outbreak OR protest)
GDELT_MAX_RECORDS=50

# --- Live Data Providers ---

# OpenSky Flights (OAuth2 — register at https://opensky-network.org)
# Minimum interval is 60s (4 credits/call, 4000 credits/day quota)
OPENSKY_ENABLED=false
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
OPENSKY_INTERVAL_SECONDS=120
OPENSKY_MAX_AIRCRAFT=500

# AIS Ships (AISHub — register at https://www.aishub.net)
AIS_ENABLED=false
AIS_INTERVAL_SECONDS=120
AIS_MAX_VESSELS=300
AISHUB_USERNAME=

# Satellites (Celestrak TLE — free, no key required)
CELESTRAK_ENABLED=false
SATELLITE_INTERVAL_SECONDS=300
SATNOGS_INTERVAL_SECONDS=600

# Conflicts (UCDP — free token required, register at https://ucdpapi.pcr.uu.se)
UCDP_ENABLED=false
UCDP_INTERVAL_SECONDS=3600
UCDP_API_TOKEN=

# Threat Intelligence (Abuse.ch feeds — free, no key required)
THREAT_INTEL_ENABLED=false
THREAT_INTEL_INTERVAL_SECONDS=300

# ACLED Armed Conflict Data (register at https://acleddata.com)
ACLED_API_KEY=
ACLED_EMAIL=
